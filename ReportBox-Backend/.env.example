# Express backend (reports / OTP / admin). Copy to .env for local dev; in
# production set these in the Vercel (or Render) dashboard.

# MongoDB Atlas connection string (free M0 cluster)
MONGODB_URI=

# Secret used to sign admin JWTs (use a long random value)
JWT_SECRET=

# Admin dashboard password (server-side only)
ADMIN_PASSWORD=

# Allowed CORS origin — the deployed frontend ORIGIN only, no path.
# For GitHub Pages this is https://<user>.github.io (NOT .../Sevak/).
FRONTEND_URL=

# Twilio Verify (only needed for the phone OTP feature; optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# Local port (ignored on Vercel; defaults to 3000)
PORT=3000
