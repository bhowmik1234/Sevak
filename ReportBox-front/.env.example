# Frontend build-time config (Vite). Copy to .env.local for local dev.
# In CI (GitHub Pages), these are injected from repo Variables/Secrets — see DEPLOY.md.

# Base path the app is served from.
#   GitHub Pages project site -> /Sevak/
#   Vercel / Cloudflare / custom domain at root -> /
VITE_BASE=/

# FastAPI backend (auth + chat + documents), e.g. https://sevak-fastapi.onrender.com
VITE_BACKEND_URL=

# Express backend (reports + OTP + admin + tracking), e.g. https://sevak-reportbox.vercel.app
VITE_BASE_URL=

# Cloudinary CLOUD NAME (not an API key) for report media uploads.
# Requires an UNSIGNED upload preset named "ReportBox" in your Cloudinary account.
VITE_CLOUDINARY_CLOUD_NAME=
# Deprecated alias — still read as a fallback if the one above is unset.
# VITE_CLOUDINARY_KEY=

# OpenCage geocoding API key (used by the Report form)
VITE_LOCATION_KEY=
