# FastAPI backend (Legal Assistant + RAG). Copy to .env for local dev; in
# production set these in the Render dashboard.

# --- Required ---
# PostgreSQL connection string (Neon free tier). Use the POOLED connection URL.
DATABASE_URL=
# Secret used to sign user JWTs (long random value)
JWT_SECRET=
# Google Gemini API key
GOOGLE_API_KEY=
# Allowed CORS origin — the deployed frontend ORIGIN only, no path.
# For GitHub Pages this is https://<user>.github.io (NOT .../Sevak/).
FRONTEND_URL=

# --- Vector store: Pinecone serverless (free starter) ---
VECTOR_STORE=pinecone
PINECONE_API_KEY=
# Defaults match the free starter (one index, aws/us-east-1). The index
# auto-creates on first ingest. Change only if your index differs.
PINECONE_INDEX=sevak
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Alternative vector store (self-host / Qdrant Cloud): set VECTOR_STORE=qdrant
# and provide QDRANT_URL + QDRANT_API_KEY instead of the Pinecone vars above.
# QDRANT_URL=
# QDRANT_API_KEY=

# --- Admin PDF ingestion ---
# Shared secret for POST /admin/upload-pdf (X-Admin-Key header)
ADMIN_API_KEY=

# --- RAG: free profile (all via Gemini API, no local ML) ---
EMBEDDINGS_PROVIDER=gemini
LLM_PROVIDER=gemini
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
RELEVANCE_THRESHOLD=0.30
GROUNDEDNESS_ENABLED=true
GROUNDEDNESS_METHOD=judge
QUERY_REWRITE_ENABLED=true

# --- Optional tuning ---
JWT_EXPIRE_MINUTES=1440
CLEANUP_INTERVAL_MINUTES=60
MESSAGE_RETENTION_MINUTES=1440
